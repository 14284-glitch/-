# 執行環境
APP_ENV=development
LOG_LEVEL=INFO
TIMEZONE=Asia/Taipei

# Google Cloud / BigQuery（勿將真實憑證提交至版本庫）
GCP_PROJECT_ID=your-gcp-project-id
BIGQUERY_DATASET=stock_predictor
GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account.json
BIGQUERY_LOCATION=asia-east1

# 資料來源（僅在採用需金鑰的供應商時填寫）
FINMIND_API_TOKEN=
FRED_API_KEY=
ALPHA_VANTAGE_API_KEY=

# 模型與資料版本
FEATURE_VERSION=v1
MODEL_ARTIFACT_DIR=artifacts/models

# 訊號門檻（集中設定，可依研究結果調整）
SIGNAL_STRONG_BUY_THRESHOLD=0.70
SIGNAL_BULLISH_THRESHOLD=0.60
SIGNAL_BEARISH_THRESHOLD=0.40
SIGNAL_HIGH_RISK_THRESHOLD=0.30

# 回測預設值
BACKTEST_COMMISSION_RATE=0.001425
BACKTEST_TRANSACTION_TAX_RATE=0.003
BACKTEST_SLIPPAGE_RATE=0.001
BACKTEST_MAX_POSITIONS=10
BACKTEST_MAX_POSITION_WEIGHT=0.20

